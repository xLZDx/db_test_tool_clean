# ── AI (OpenAI) ─────────────────────────────
AI_PROVIDER=openai
AI_MODEL=gpt-4o
AI_BASE_URL=
AI_API_KEY=
AI_HTTP_TIMEOUT_SECONDS=25
GITHUBCOPILOT_BASE_URL=
GITHUBCOPILOT_API_KEY=
GITHUBCOPILOT_MODEL=
GITHUBCOPILOT_EDITOR_VERSION=vscode/1.98.0
GITHUBCOPILOT_EDITOR_PLUGIN_VERSION=copilot-chat/0.26.7
GITHUBCOPILOT_INTEGRATION_ID=vscode-chat
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_SCOPE=read:user copilot
REDSHIFT_DEFAULT_SESSION_MINUTES=480
AUTO_APPROVE_CONFIRMATIONS=true
COPILOT_AUTH_MODE=automatic

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_VERIFY_SSL=true
OPENAI_CA_BUNDLE=

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=

